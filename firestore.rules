rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper function to check if user is the owner
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // System config - Admin only for write, all auth for read
    match /system_config/{doc} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Jira cache collections - Allow authenticated write for persistence
    match /jira_cache/{doc} {
      allow read, write: if request.auth != null; 
    }
    match /epic_progress_cache/{doc} {
      allow read, write: if request.auth != null; 
    }
    match /extra_epics_summary/{doc} {
      allow read, write: if request.auth != null; 
    }
    
    // Users - Self or admin
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }
    
    // User settings - Self only
    match /user_settings/{userId} {
      allow read, write: if isOwner(userId);
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // All other collections
    match /strategic_objectives/{doc} { allow read, write: if request.auth != null || isAdmin(); }
    match /manual_okrs/{doc} { allow read, write: if request.auth != null || isAdmin(); }
    match /strategic_epics/{doc} { allow read, write: if request.auth != null || isAdmin(); }
    match /strategic_teams/{doc} { allow read, write: if request.auth != null || isAdmin(); }
    match /strategic_notes/{doc} { allow read, write: if request.auth != null || isAdmin(); }
    match /time_entries/{doc} { allow read, write: if request.auth != null || isAdmin(); }
    match /ai_insights/{doc} { allow read, write: if request.auth != null || isAdmin(); }
    match /system_logs/{doc} { allow create: if request.auth != null; allow read: if isAdmin(); }
    match /config/{doc} { allow read, write: if isAdmin(); }
    match /calculation_rules/{doc} { allow read, write: if request.auth != null || isAdmin(); }
    match /system_config/{doc} { allow read: if request.auth != null; allow write: if isAdmin(); }

    // Admin catch-all: Override ANY denial for admins
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
